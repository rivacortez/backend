# Copy to .env and fill in. .env is gitignored.

# PostgreSQL 17 LOCAL para desarrollo (docker-compose.yml → pgvector/pgvector:pg17).
# Levanta la DB con: docker compose up -d   (crea gastronomia_dev + el rol gastronomia_app).
# Producción usa Neon (PG17 + pgvector): se sobreescribe esta línea al desplegar.
#
# Runtime tenant-scoped: rol NO-superuser gastronomia_app → la RLS (FORCE) le aplica.
DATABASE_URL=
# Admin (superuser, BYPASEA RLS): solo para seeding de tests / provisioning. NUNCA en requests.
DATABASE_URL_ADMIN=
# Auth lookup (NOSUPERUSER pero BYPASSRLS, solo SELECT): solo para login (la auth precede al tenant).
DATABASE_URL_AUTH=

# Puerto HTTP del backend. 3333 para NO chocar con Nuxt dev (3000);
# el BFF de Nitro proxea aquí (NUXT_API_BASE=<backend-origin>).
PORT=3333

# JWT RS256 (PEM en base64). Genera las claves de dev con: bun run keys:gen
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Demo deployment provider settings (set securely in Render; leave sample values blank).
REDIS_URL=
CORE_AI_URL=
CORE_AI_TIMEOUT_MS=
