// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// E01 — Identity & Multi-Tenancy. Convenciones (backend.md §6): snake_case en BD,
// tenant_id UUID NOT NULL en toda tabla de negocio, soft delete (deleted_at).
// La RLS FORCE + policies se añaden en el SQL de la migración (no se expresan en
// el schema Prisma). Ver prisma/migrations/**/migration.sql.

model Tenant {
  id   String @id @default(uuid()) @db.Uuid
  name String

  // Configuración del local (HU-01-10). Moneda solo PEN (backend.md §6).
  ruc           String? // RUC fiscal (11 dígitos) — validado en la capa Zod
  legalName     String? @map("legal_name")
  fiscalAddress String? @map("fiscal_address")
  currency      String  @default("PEN")
  igvRate       Float   @default(0.18) @map("igv_rate")
  capacity      Int? // aforo
  businessHours Json?   @map("business_hours")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  users              User[]
  ingredients        Ingredient[]
  unitsOfMeasure     UnitOfMeasure[]
  categories         Category[]
  suppliers          Supplier[]
  recipes            Recipe[]
  menuCategories     MenuCategory[]
  menuItems          MenuItem[]
  menuModifiers      MenuModifier[]
  menuAvailability   MenuAvailability[]
  zones              Zone[]
  diningTables       DiningTable[]
  orders             Order[]
  kitchenStations    KitchenStation[]
  inventoryMovements InventoryMovement[]
  purchaseOrders     PurchaseOrder[]
  sales              Sale[]
  payments           Payment[]
  cashCloses         CashClose[]
  overheadCosts      OverheadCost[]

  @@map("tenants")
}

// HU-03-07: estación de cocina (parrilla, frío, barra…). Enruta los ítems de una
// orden hacia un puesto del KDS vía la categoría de menú del plato. position = orden visual.
model KitchenStation {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  name      String
  position  Int       @default(0)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tenant         Tenant         @relation(fields: [tenantId], references: [id])
  menuCategories MenuCategory[]

  @@index([tenantId])
  @@map("kitchen_stations")
}

// HU-03-01: zona del salón (terraza, salón, barra…). position = orden visual.
model Zone {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  name      String
  position  Int       @default(0)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tenant Tenant        @relation(fields: [tenantId], references: [id])
  tables DiningTable[]

  @@index([tenantId])
  @@map("zones")
}

// HU-03-01/02/03: mesa del salón. code único por tenant; status del mapa POS.
// status: free | occupied | bill_requested | cleaning.
model DiningTable {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  zoneId    String    @map("zone_id") @db.Uuid
  code      String
  capacity  Int       @default(2)
  status    String    @default("free")
  posX      Int?      @map("pos_x")
  posY      Int?      @map("pos_y")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  zone   Zone    @relation(fields: [zoneId], references: [id])
  orders Order[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([zoneId])
  @@map("dining_tables")
}

// HU-03-03/04/05/10/11/12: orden (cuenta) abierta sobre una mesa. waiterId = mesero
// que abrió. status: open | sent_to_kitchen | served | void | paid. idempotencyKey
// permite reintentos seguros al abrir mesa (Postgres permite múltiples NULL en el
// índice único, así que aperturas sin clave no colisionan).
model Order {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  tableId         String    @map("table_id") @db.Uuid
  waiterId        String?   @map("waiter_id") @db.Uuid
  guests          Int       @default(1)
  status          String    @default("open")
  voidReason      String?   @map("void_reason")
  idempotencyKey  String?   @map("idempotency_key")
  openedAt        DateTime  @default(now()) @map("opened_at")
  sentToKitchenAt DateTime? @map("sent_to_kitchen_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  tenant Tenant      @relation(fields: [tenantId], references: [id])
  table  DiningTable @relation(fields: [tableId], references: [id])
  waiter User?       @relation(fields: [waiterId], references: [id])
  items  OrderItem[]
  sale   Sale?

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId])
  @@index([tableId])
  @@map("orders")
}

// HU-04-02 · Ticket/comprobante de una orden cobrada. Un ticket por orden
// (orderId único). serie+number = correlativo por tenant (B001/F001…). Los
// montos incluyen IGV: total = Σ ítems; subtotal = total/(1+igvRate); igv = total−subtotal.
// status: issued | void. El envío electrónico a SUNAT es externo/fuera de alcance
// (schema preparado). docType: boleta | factura.
model Sale {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  orderId     String   @map("order_id") @db.Uuid
  serie       String
  number      Int
  docType     String   @map("doc_type")
  customer    String?
  customerDoc String?  @map("customer_doc")
  subtotal    Decimal  @db.Decimal(12, 2)
  igv         Decimal  @db.Decimal(12, 2)
  total       Decimal  @db.Decimal(12, 2)
  status      String   @default("issued")
  voidReason  String?  @map("void_reason")
  issuedAt    DateTime @default(now()) @map("issued_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  order    Order     @relation(fields: [orderId], references: [id])
  payments Payment[]

  @@unique([orderId])
  @@unique([tenantId, serie, number])
  @@index([tenantId])
  @@map("sales")
}

// HU-04-04/05/06 · Pago de un ticket. Varios pagos por venta → pago mixto.
// method: cash | card | yape | plin (sin pasarela; solo registro).
model Payment {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  saleId    String   @map("sale_id") @db.Uuid
  method    String
  amount    Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  sale   Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@index([tenantId])
  @@map("payments")
}

// HU-04-08 · Cierre Z del día. Agrega las ventas emitidas de la ventana abierta
// (desde el último cierre) y queda INMUTABLE (append-only): totales por método de
// pago + conteos. `byMethod` = JSON { cash, card, yape, plin } con montos string.
model CashClose {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  openedAt   DateTime @map("opened_at")
  closedAt   DateTime @default(now()) @map("closed_at")
  salesCount Int      @map("sales_count")
  voidCount  Int      @map("void_count")
  totalGross Decimal  @map("total_gross") @db.Decimal(12, 2)
  byMethod   Json     @map("by_method")
  userId     String?  @map("user_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("cash_closes")
}

// HU-03-04/05/10: ítem de una orden. name/unitPrice/modifiers son SNAPSHOTS del
// momento (el precio incluye los modificadores). status: pending | preparing |
// ready | served. kitchenStationId reservado para Inc C (KDS) — sin FK aún.
model OrderItem {
  id               String    @id @default(uuid()) @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  orderId          String    @map("order_id") @db.Uuid
  menuItemId       String    @map("menu_item_id") @db.Uuid
  name             String
  qty              Int
  unitPrice        Decimal   @map("unit_price") @db.Decimal(12, 2)
  notes            String?
  modifiers        Json      @default("[]")
  status           String    @default("pending")
  kitchenStationId String?   @map("kitchen_station_id") @db.Uuid
  sentToKitchenAt  DateTime? @map("sent_to_kitchen_at")
  preparingAt      DateTime? @map("preparing_at")
  readyAt          DateTime? @map("ready_at")
  servedAt         DateTime? @map("served_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  deletedAt        DateTime? @map("deleted_at")

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@index([orderId])
  @@index([tenantId])
  @@map("order_items")
}

// HU-02-07/08/09: receta estandarizada (BOM). kind dish|sub_recipe; yield (rendimiento).
model Recipe {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  name        String
  kind        String    @default("dish")
  yield       Decimal   @default(1) @db.Decimal(12, 3)
  version     Int       @default(1)
  // Presentación (consumida por el frontend; aplica a platos y sub-recetas).
  emoji       String?
  description String?
  prepMinutes Int?      @map("prep_minutes")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  tenant    Tenant          @relation(fields: [tenantId], references: [id])
  items     RecipeItem[]    @relation("RecipeItems")
  usedIn    RecipeItem[]    @relation("SubRecipe")
  versions  RecipeVersion[]
  menuItems MenuItem[]

  @@index([tenantId])
  @@map("recipes")
}

// HU-02-12: categoría de la carta (entradas, principales, postres, bebidas).
// Distinta de Category (catálogo de insumos). position = orden en POS; isActive = visible.
model MenuCategory {
  id               String    @id @default(uuid()) @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  name             String
  position         Int       @default(0)
  isActive         Boolean   @default(true) @map("is_active")
  // HU-03-07: estación de cocina destino para los platos de esta categoría (opcional).
  kitchenStationId String?   @map("kitchen_station_id") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  kitchenStation KitchenStation? @relation(fields: [kitchenStationId], references: [id])
  items          MenuItem[]

  @@index([tenantId])
  @@map("menu_categories")
}

// HU-02-10: plato vendible. Asociado a una receta (para costo/margen) + precio de venta.
// imageUrl queda para HU-02-14 (subida a R2 diferida). isActive = visible en POS.
model MenuItem {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  recipeId       String    @map("recipe_id") @db.Uuid
  menuCategoryId String?   @map("menu_category_id") @db.Uuid
  name           String
  price          Decimal   @db.Decimal(12, 2)
  imageUrl       String?   @map("image_url")
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  tenant       Tenant             @relation(fields: [tenantId], references: [id])
  recipe       Recipe             @relation(fields: [recipeId], references: [id])
  menuCategory MenuCategory?      @relation(fields: [menuCategoryId], references: [id])
  modifiers    MenuModifier[]
  availability MenuAvailability[]
  orderItems   OrderItem[]

  @@index([tenantId])
  @@index([menuCategoryId])
  @@map("menu_items")
}

// HU-02-11: modificador opcional de un plato (extra queso, sin cebolla, picante).
// priceDelta puede ser negativo. required = debe elegirse antes de enviar a cocina (se aplica en POS, E03).
model MenuModifier {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  menuItemId String    @map("menu_item_id") @db.Uuid
  name       String
  priceDelta Decimal   @default(0) @map("price_delta") @db.Decimal(12, 2)
  required   Boolean   @default(false)
  position   Int       @default(0)
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@index([menuItemId])
  @@index([tenantId])
  @@map("menu_modifiers")
}

// HU-02-13: ventana horaria de disponibilidad de un plato (carta de almuerzo vs cena).
// dayOfWeek 0=domingo..6=sábado; null = todos los días. Minutos desde medianoche (hora del tenant, America/Lima).
model MenuAvailability {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  menuItemId  String   @map("menu_item_id") @db.Uuid
  dayOfWeek   Int?     @map("day_of_week")
  startMinute Int      @map("start_minute")
  endMinute   Int      @map("end_minute")
  createdAt   DateTime @default(now()) @map("created_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@index([menuItemId])
  @@index([tenantId])
  @@map("menu_availability")
}

// Línea de BOM: referencia un ingrediente O una sub-receta (XOR), con qty y merma.
model RecipeItem {
  id           String  @id @default(uuid()) @db.Uuid
  tenantId     String  @map("tenant_id") @db.Uuid
  recipeId     String  @map("recipe_id") @db.Uuid
  ingredientId String? @map("ingredient_id") @db.Uuid
  subRecipeId  String? @map("sub_recipe_id") @db.Uuid
  qty          Decimal @db.Decimal(12, 3)
  wasteFactor  Decimal @default(0) @map("waste_factor") @db.Decimal(5, 4)

  recipe     Recipe      @relation("RecipeItems", fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient Ingredient? @relation(fields: [ingredientId], references: [id])
  subRecipe  Recipe?     @relation("SubRecipe", fields: [subRecipeId], references: [id])

  @@index([recipeId])
  @@index([tenantId])
  @@map("recipe_items")
}

// HU-02-09: snapshot inmutable de una versión de la receta (con costo del momento).
model RecipeVersion {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  recipeId  String   @map("recipe_id") @db.Uuid
  version   Int
  snapshot  Json
  createdAt DateTime @default(now()) @map("created_at")

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId])
  @@map("recipe_versions")
}

// HU-02-05: proveedores (RUC 11 díg., contacto, lead time). Soft delete / desactivar.
model Supplier {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  ruc          String
  name         String
  contactName  String?   @map("contact_name")
  contactEmail String?   @map("contact_email")
  contactPhone String?   @map("contact_phone")
  paymentTerms String?   @map("payment_terms")
  leadTimeDays Int?      @map("lead_time_days")
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  productSuppliers ProductSupplier[]
  purchaseOrders   PurchaseOrder[]

  @@unique([tenantId, ruc])
  @@index([tenantId])
  @@map("suppliers")
}

// HU-02-06: relación insumo ↔ proveedor (SKU del proveedor, último precio, preferido).
model ProductSupplier {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  ingredientId String   @map("ingredient_id") @db.Uuid
  supplierId   String   @map("supplier_id") @db.Uuid
  supplierSku  String?  @map("supplier_sku")
  lastPrice    Decimal? @map("last_price") @db.Decimal(12, 2)
  preferred    Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  ingredient Ingredient @relation(fields: [ingredientId], references: [id])
  supplier   Supplier   @relation(fields: [supplierId], references: [id])

  @@unique([ingredientId, supplierId])
  @@index([tenantId])
  @@map("product_suppliers")
}

// HU-02-03: unidades de medida con factor de conversión a la base de su familia.
model UnitOfMeasure {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  code         String
  name         String
  family       String // mass | volume | count
  factorToBase Decimal   @default(1) @map("factor_to_base") @db.Decimal(18, 6)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("units_of_measure")
}

// HU-02-04: categorías jerárquicas (árbol). Sin ciclos; sin borrar con hijas.
model Category {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  name      String
  parentId  String?   @map("parent_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tenant   Tenant     @relation(fields: [tenantId], references: [id])
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")

  @@index([tenantId])
  @@map("categories")
}

// E02 — Catálogo. HU-02-01: insumos (productos base). SKU único por tenant,
// soft delete. `unit`/`category` son strings por ahora (FK a units_of_measure /
// categorías en HU-02-03/04). Costo en Decimal (money, backend.md §6).
model Ingredient {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  sku       String
  name      String
  type      String
  unit      String
  category  String?
  unitCost  Decimal   @default(0) @map("unit_cost") @db.Decimal(12, 2)
  // Inventario (E05). Diferidos en E02; E05 los gobierna. stock = on-hand actual,
  // minStock = umbral de reorden (alertas de stock bajo, HU-05-10).
  stock     Decimal   @default(0) @db.Decimal(12, 3)
  minStock  Decimal   @default(0) @map("min_stock") @db.Decimal(12, 3)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  productSuppliers   ProductSupplier[]
  recipeItems        RecipeItem[]
  inventoryMovements InventoryMovement[]
  purchaseOrderItems PurchaseOrderItem[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@map("ingredients")
}

// HU-05-01/02/03/08: movimiento de inventario (kardex event-sourced). qty es un
// DELTA CON SIGNO (positivo = entrada/compra; negativo = salida/venta/merma) que
// se suma al stock del insumo. type: purchase|sale|waste|adjustment|count.
// reason obligatorio para mermas (waste, HU-05-08). userId = JWT sub (quién lo hizo).
model InventoryMovement {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  ingredientId String   @map("ingredient_id") @db.Uuid
  type         String
  qty          Decimal  @db.Decimal(12, 3)
  note         String?
  reason       String?
  userId       String?  @map("user_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])

  @@index([tenantId])
  @@index([ingredientId])
  @@map("inventory_movements")
}

// HU-05-04/05/06/07: orden de compra (OC) a un proveedor. Máquina de estados:
// draft → sent → partially_received → received (terminal); cancelled (terminal).
// status: draft|sent|partially_received|received|cancelled. expectedAt = fecha
// esperada de entrega. El total (Σ qtyOrdered·unitCost) se calcula en la vista.
model PurchaseOrder {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  supplierId String    @map("supplier_id") @db.Uuid
  status     String    @default("draft")
  notes      String?
  expectedAt DateTime? @map("expected_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  tenant   Tenant              @relation(fields: [tenantId], references: [id])
  supplier Supplier            @relation(fields: [supplierId], references: [id])
  items    PurchaseOrderItem[]

  @@index([tenantId])
  @@index([supplierId])
  @@map("purchase_orders")
}

// HU-05-04/06: línea de una OC. qtyOrdered = cantidad pedida; qtyReceived =
// acumulado recibido (recepciones parciales, HU-05-06); unitCost = precio de
// compra pactado por unidad. Al recibir se crea un inventory_movement
// type='purchase' y se sube ingredient.stock + se fija ingredient.unitCost.
model PurchaseOrderItem {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  purchaseOrderId String   @map("purchase_order_id") @db.Uuid
  ingredientId    String   @map("ingredient_id") @db.Uuid
  qtyOrdered      Decimal  @map("qty_ordered") @db.Decimal(12, 3)
  qtyReceived     Decimal  @default(0) @map("qty_received") @db.Decimal(12, 3)
  unitCost        Decimal  @map("unit_cost") @db.Decimal(12, 2)
  createdAt       DateTime @default(now()) @map("created_at")

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  ingredient    Ingredient    @relation(fields: [ingredientId], references: [id])

  @@index([tenantId])
  @@index([purchaseOrderId])
  @@index([ingredientId])
  @@map("purchase_order_items")
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  // Email global-unique para login-por-email en el piloto (1 tenant). El soporte
  // multi-org del mismo email se difiere a Better-Auth (HU-E01-03).
  email        String    @unique
  name         String
  passwordHash String    @map("password_hash")
  // AppRole[] ('owner'|'manager'|'staff'). Validado en la capa Zod (appRoleSchema).
  roles        String[]  @default([])
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  // Lockout tras intentos fallidos (HU-01-02).
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until")

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  refreshTokens RefreshToken[]
  orders        Order[]

  @@index([tenantId])
  @@map("users")
}

// HU-01-09: audit log inmutable de acciones críticas (Ley 29733). Append-only
// (trigger en la migración bloquea UPDATE/DELETE). RLS FORCE por tenant.
model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  action    String
  ip        String?
  userAgent String?  @map("user_agent")
  meta      Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@map("audit_logs")
}

// HU-01-03: refresh tokens opacos con rotación. Se guarda solo el SHA-256.
model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  // Familia de rotación: reusar un token revocado revoca TODA la familia.
  family    String    @db.Uuid
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([family])
  @@map("refresh_tokens")
}

// HU-06-02 · Costo indirecto de fabricación (CIF) mensual: gastos fijos/indirectos
// del local (alquiler, sueldos, servicios, marketing…) registrados por período
// `YYYY-MM`. Se prorratean entre los platos vendidos del período (HU-06-03) para
// obtener el costo total por plato (ingredientes + CIF). amount = PEN.
model OverheadCost {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  period    String // YYYY-MM
  concept   String
  amount    Decimal   @db.Decimal(12, 2)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([period])
  @@map("overhead_costs")
}
