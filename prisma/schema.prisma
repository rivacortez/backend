// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// E01 — Identity & Multi-Tenancy. Convenciones (backend.md §6): snake_case en BD,
// tenant_id UUID NOT NULL en toda tabla de negocio, soft delete (deleted_at).
// La RLS FORCE + policies se añaden en el SQL de la migración (no se expresan en
// el schema Prisma). Ver prisma/migrations/**/migration.sql.

model Tenant {
  id   String @id @default(uuid()) @db.Uuid
  name String

  // Configuración del local (HU-01-10). Moneda solo PEN (backend.md §6).
  ruc           String? // RUC fiscal (11 dígitos) — validado en la capa Zod
  legalName     String? @map("legal_name")
  fiscalAddress String? @map("fiscal_address")
  currency      String  @default("PEN")
  igvRate       Float   @default(0.18) @map("igv_rate")
  capacity      Int? // aforo
  businessHours Json?   @map("business_hours")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  users          User[]
  ingredients    Ingredient[]
  unitsOfMeasure UnitOfMeasure[]
  categories     Category[]
  suppliers      Supplier[]

  @@map("tenants")
}

// HU-02-05: proveedores (RUC 11 díg., contacto, lead time). Soft delete / desactivar.
model Supplier {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  ruc          String
  name         String
  contactName  String?   @map("contact_name")
  contactEmail String?   @map("contact_email")
  contactPhone String?   @map("contact_phone")
  paymentTerms String?   @map("payment_terms")
  leadTimeDays Int?      @map("lead_time_days")
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  productSuppliers ProductSupplier[]

  @@unique([tenantId, ruc])
  @@index([tenantId])
  @@map("suppliers")
}

// HU-02-06: relación insumo ↔ proveedor (SKU del proveedor, último precio, preferido).
model ProductSupplier {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  ingredientId String   @map("ingredient_id") @db.Uuid
  supplierId   String   @map("supplier_id") @db.Uuid
  supplierSku  String?  @map("supplier_sku")
  lastPrice    Decimal? @db.Decimal(12, 2) @map("last_price")
  preferred    Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  ingredient Ingredient @relation(fields: [ingredientId], references: [id])
  supplier   Supplier   @relation(fields: [supplierId], references: [id])

  @@unique([ingredientId, supplierId])
  @@index([tenantId])
  @@map("product_suppliers")
}

// HU-02-03: unidades de medida con factor de conversión a la base de su familia.
model UnitOfMeasure {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  code         String
  name         String
  family       String // mass | volume | count
  factorToBase Decimal   @default(1) @db.Decimal(18, 6) @map("factor_to_base")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("units_of_measure")
}

// HU-02-04: categorías jerárquicas (árbol). Sin ciclos; sin borrar con hijas.
model Category {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  name      String
  parentId  String?   @map("parent_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tenant   Tenant     @relation(fields: [tenantId], references: [id])
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")

  @@index([tenantId])
  @@map("categories")
}

// E02 — Catálogo. HU-02-01: insumos (productos base). SKU único por tenant,
// soft delete. `unit`/`category` son strings por ahora (FK a units_of_measure /
// categorías en HU-02-03/04). Costo en Decimal (money, backend.md §6).
model Ingredient {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  sku       String
  name      String
  type      String
  unit      String
  category  String?
  unitCost  Decimal   @default(0) @db.Decimal(12, 2) @map("unit_cost")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  productSuppliers ProductSupplier[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@map("ingredients")
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  // Email global-unique para login-por-email en el piloto (1 tenant). El soporte
  // multi-org del mismo email se difiere a Better-Auth (HU-E01-03).
  email        String    @unique
  name         String
  passwordHash String    @map("password_hash")
  // AppRole[] ('owner'|'manager'|'staff'). Validado en la capa Zod (appRoleSchema).
  roles        String[]  @default([])
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  // Lockout tras intentos fallidos (HU-01-02).
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until")

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  refreshTokens RefreshToken[]

  @@index([tenantId])
  @@map("users")
}

// HU-01-09: audit log inmutable de acciones críticas (Ley 29733). Append-only
// (trigger en la migración bloquea UPDATE/DELETE). RLS FORCE por tenant.
model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  action    String
  ip        String?
  userAgent String?  @map("user_agent")
  meta      Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@map("audit_logs")
}

// HU-01-03: refresh tokens opacos con rotación. Se guarda solo el SHA-256.
model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  // Familia de rotación: reusar un token revocado revoca TODA la familia.
  family    String    @db.Uuid
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([family])
  @@map("refresh_tokens")
}
